# Build stage
FROM eclipse-temurin:21-jdk as builder
WORKDIR /application
COPY . .
RUN --mount=type=cache,target=/root/.gradle ./gradlew clean build -x test

# Runtime stage with NVIDIA OpenGL + EGL (no X11/Xvfb)
FROM nvidia/opengl:1.2-glvnd-runtime-ubuntu22.04
ENV DEBIAN_FRONTEND=noninteractive
WORKDIR /application

# Java runtime + EGL; Xvfb для fallback (GLX); libharfbuzz/fontconfig для stub
RUN apt-get update && apt-get install -y --no-install-recommends \
    openjdk-21-jre-headless \
    libegl1 \
    libgles2 \
    libharfbuzz0b \
    fontconfig \
    xvfb \
    libx11-6 libxext6 libxrender1 \
    ca-certificates \
  && rm -rf /var/lib/apt/lists/*

# Copy fat jar
COPY --from=builder /application/build/libs/*.jar /application/app.jar

# NVIDIA container runtime env
ENV NVIDIA_VISIBLE_DEVICES=all \
    NVIDIA_DRIVER_CAPABILITIES=compute,utility,graphics

EXPOSE 8010
# Сначала пробуем без DISPLAY (EGL). Если EGL не поднялся — при следующем запуске можно использовать Xvfb:
# Xvfb :99 -screen 0 1920x1080x24 & sleep 2 && export DISPLAY=:99 __GLX_VENDOR_LIBRARY_NAME=nvidia && exec java -jar /application/app.jar
ENTRYPOINT ["bash", "-c", "Xvfb :99 -screen 0 1920x1080x24 & sleep 2 && export DISPLAY=:99 && export __GLX_VENDOR_LIBRARY_NAME=nvidia 2>/dev/null; exec java -jar /application/app.jar"] 